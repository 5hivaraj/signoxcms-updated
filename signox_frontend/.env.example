# Copy to .env and adjust for your environment.
# Local backend (same machine): http://localhost:5000/api
# Production (canonical host, no www): https://signoxcms.com/api

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Build-time (read when you run `next build`). Comma-separated hosts as Next expects for Server Actions (host, or host:port — no scheme).
# Example behind nginx TLS: signoxcms.com
# Example direct to Node: ec2-xx-xx-xx-xx.compute.amazonaws.com:3000
# SERVER_ACTION_ALLOWED_ORIGINS=signoxcms.com

# Optional: comma-separated hostnames for next/image remote sources (no scheme, no path).
# NEXT_IMAGE_REMOTE_HOSTS=signoxcms.com,api.signoxcms.com